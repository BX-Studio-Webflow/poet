# Workday Recruiting API (OAuth 2.0)
# Get these from Workday: API Clients for Integrations + Manage Refresh Tokens

WORKDAY_BASE_URL=https://wd2-impl-services1.workday.com/ccx
WORKDAY_TENANT=poet_preview
WORKDAY_CLIENT_ID=your_client_id
WORKDAY_CLIENT_SECRET=your_client_secret
WORKDAY_REFRESH_TOKEN=your_refresh_token

# Optional: Base URL for career site (used when API returns relative externalPath)
# WORKDAY_CAREER_SITE_URL=https://poet.wd1.myworkdayjobs.com
